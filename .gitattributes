# Auto-detect text files and perform LF normalization
* text=auto

# Force LF for shell scripts and unix-y files (would break otherwise on Linux/macOS)
*.sh           text eol=lf
install.sh     text eol=lf

# Force CRLF for PowerShell (Windows-native)
*.ps1          text eol=crlf

# Markdown — let git decide (most editors handle both)
*.md           text

# Binary
*.png          binary
*.jpg          binary
*.gif          binary
*.ico          binary
